# ================================================
# ENVIRONMENT VARIABLES - INVENTORY MANAGEMENT SYSTEM
# ================================================
# This file is a safe template — commit it to git.
# Copy to .env and fill in your actual values.
# NEVER commit the real .env file.
# ================================================

# ----------------------------------------------
# Backend API Configuration
# ----------------------------------------------
# Full URL of your backend API (including /api prefix)
# Dev:  http://localhost:5000/api
# Prod: https://your-production-domain.com/api
VITE_API_BASE_URL=http://localhost:5000/api

# Backend server base URL (used by Vite dev proxy only)
VITE_BACKEND_URL=http://localhost:5000

# ----------------------------------------------
# Cloudinary (Image / File Upload Service)
# Get these from: https://cloudinary.com/console
# ----------------------------------------------
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# ----------------------------------------------
# Google Gemini AI (Dashboard Insights)
# Get your key from: https://aistudio.google.com/app/apikey
# ----------------------------------------------
GEMINI_API_KEY=your_gemini_api_key
